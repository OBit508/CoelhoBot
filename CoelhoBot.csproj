<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\Config.json" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\Config.json" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NetCord" Version="1.0.0-alpha.469" />
    <PackageReference Include="NetCord.Hosting" Version="1.0.0-alpha.469" />
    <PackageReference Include="NetCord.Hosting.AspNetCore" Version="1.0.0-alpha.469" />
    <PackageReference Include="NetCord.Hosting.Services" Version="1.0.0-alpha.469" />
    <PackageReference Include="NetCord.Services" Version="1.0.0-alpha.469" />
  </ItemGroup>

</Project>
